{
  "name": "ni-lang",
  "displayName": "Ni Language",
  "description": "Syntax highlighting and language support for the Ni programming language",
  "version": "0.1.0",
  "publisher": "ni-lang",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:ni"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "ni",
        "aliases": [
          "Ni",
          "ni"
        ],
        "extensions": [
          ".ni"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "ni",
        "scopeName": "source.ni",
        "path": "./syntaxes/ni.tmLanguage.json"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.75.0",
    "typescript": "^5.3.0"
  }
}
